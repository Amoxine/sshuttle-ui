{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the sshuttle UI desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:event:default",
    "core:tray:default",
    "core:menu:default",
    "core:webview:default",
    "core:app:default",
    "core:resources:default",
    "shell:default",
    "shell:allow-open",
    "dialog:default",
    "notification:default",
    "os:default"
  ]
}
