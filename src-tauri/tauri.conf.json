{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sshuttle UI",
  "version": "1.0.1",
  "identifier": "io.sshuttle.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "sshuttle UI",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost https://*; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Modern desktop GUI for sshuttle",
    "longDescription": "A Tailscale/Mullvad-style desktop client that uses sshuttle as its tunneling engine. Manage SSH-based VPN profiles, routes, DNS, and connection state with a modern UI.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© sshuttle-ui contributors",
    "license": "MIT",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "frameworks": []
    },
    "linux": {
      "deb": {
        "depends": ["sshuttle"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["sshuttle-ui"]
      }
    },
    "updater": {
      "active": false,
      "endpoints": [
        "https://example.com/sshuttle-ui/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": ""
    }
  }
}
