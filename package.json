{
  "name": "sshuttle-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Modern desktop GUI for sshuttle — a Tailscale-style experience powered by sshuttle.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
